[sub_resource type="GDScript" id="GDScript_s2ta7"]
resource_name = "FadeIn"
script/source = "extends Control

@onready var fade_rect = $FadeRect
@onready var press_key = $PressKeyRect
@onready var picture_intro = $TextureRect

const NORMAL_SPLASH = preload(\"C:/Users/misko/Documents/bakalarka-1/assets/menu_pictures/Good Will Browsing 2.png\")
const KERNEL_SPLASH = preload(\"C:/Users/misko/Documents/bakalarka-1/assets/menu_pictures/Good Will Browsing 2 Kernel.png\")

var can_continue := false

func _ready():
	press_key.visible = false
	
	if Global.permission_level > 0:
		picture_intro.texture = KERNEL_SPLASH
	else:
		picture_intro.texture = NORMAL_SPLASH
		
	fade_in()

	await get_tree().create_timer(2.0).timeout

	show_press_key()

func _input(event):
	if not can_continue:
		return

	if (event is InputEventKey and event.pressed) \\
	or (event is InputEventMouseButton and event.pressed):

		can_continue = false
		Transitioner.change_scene(\"res://Menus/mainMenuV4.tscn\",Transitioner.TransitionType.SIMPLE, 3.0)

func fade_in():
	var tween = create_tween()

	fade_rect.modulate.a = 1.0

	tween.set_trans(Tween.TRANS_LINEAR)

	tween.tween_property(
		fade_rect,
		\"modulate:a\",
		0.0,
		3.0
	)

func show_press_key():
	can_continue = true
	
	press_key.visible = true
	press_key.modulate.a = 0.0

	var tween = create_tween()

	tween.tween_property(
		press_key,
		\"modulate:a\",
		1.0,
		1.0
	)

	await tween.finished

	start_press_key_animation()

func start_press_key_animation():
	var tween = create_tween()

	tween.set_loops()

	tween.tween_property(
		press_key,
		\"modulate:a\",
		0.3,
		0.8
	)

	tween.tween_property(
		press_key,
		\"modulate:a\",
		1.0,
		0.8
	)
"

