[sub_resource type="GDScript" id="GDScript_5apsl"]
resource_name = "MainMenuV2Script"
script/source = "extends Control

@onready var tree: Tree = $MarginContainer/HBoxContainer/LeftPanel/VBoxContainer/Tree
@onready var content_label: RichTextLabel = $MarginContainer/RightPanel/RichTextLabel

var file_system = {
	\"new_game.exe\": {
		\"type\": \"action\",
		\"action\": \"new_game\",
		\"description\": \"Start a new game.\"
	},
	\"continue.exe\": {
		\"type\": \"action\",
		\"action\": \"load_game\",
		\"description\": \"Continue from last save.\"
	},
	\"settings.txt\": {
		\"type\": \"text\",
		\"content\": \"Graphics\\nAudio\\nControls\"
	},
	\"credits.txt\": {
		\"type\": \"text\",
		\"content\": \"Created by ...\"
	},
	\"lore\": {
		\"world.txt\": {
			\"type\": \"text\",
			\"content\": \"Long ago...\"
		},
		\"characters.txt\": {
			\"type\": \"text\",
			\"content\": \"Main cast...\"
		}
	},
	\"exit.exe\": {
		\"type\": \"action\",
		\"action\": \"quit\",
		\"description\": \"Exit the game.\"
	}
}

func _ready():
	tree.clear()
	tree.hide_root = true
	
	var root = tree.create_item()
	build_tree(root, file_system)
	
	tree.item_selected.connect(_on_tree_item_selected)

func build_tree(parent: TreeItem, data: Dictionary):
	for key in data.keys():
		var item = tree.create_item(parent)
		item.set_text(0, key)
		
		if data[key] is Dictionary and not data[key].has(\"type\"):
			item.collapsed = true
			build_tree(item, data[key])

func _on_tree_item_selected():
	var item = tree.get_selected()
	if item == null:
		return
	
	var item_text = item.get_text(0)
	var data = get_item_data(item_text, file_system)
	
	if data == null:
		return
	
	# priecinok
	if data is Dictionary and not data.has(\"type\"):
		item.collapsed = !item.collapsed
		return
	
	# textovy subor
	if data[\"type\"] == \"text\":
		if item_text == \"settings.txt\":
			open_settings()
		elif item_text == \"credits.txt\":
			show_credits()
		else:
			content_label.text = data[\"content\"]
	
	# akcny subor
	elif data[\"type\"] == \"action\":
		match data[\"action\"]:
			\"new_game\":
				start_new_game()
			\"load_game\":
				load_game()
			\"quit\":
				quit_game()

func get_item_data(item_name: String, data: Dictionary):
	for key in data.keys():
		if key == item_name:
			return data[key]
		
		if data[key] is Dictionary and not data[key].has(\"type\"):
			var result = get_item_data(item_name, data[key])
			if result != null:
				return result
	
	return null



func start_new_game():
	pass

func load_game():
	pass

func open_settings():
	pass

func show_credits():
	pass

func quit_game():
	pass
"

