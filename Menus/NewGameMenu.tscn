[gd_scene load_steps=2 format=3 uid="uid://dbon8vvcf1xym"]

[sub_resource type="GDScript" id="GDScript_5wcdi"]
resource_name = "NewGameMenuScript"
script/source = "extends Control

var selected_slot = -1

func _on_back_pressed():
	get_tree().change_scene_to_file(\"res://Menus/MainMenu.tscn\")


func _on_save_slot_1_pressed() -> void:
	select_slot(1)

func _on_save_slot_2_pressed() -> void:
	select_slot(2)

func _on_save_slot_3_pressed() -> void:
	select_slot(3)

func _on_overwrite_dialog_confirmed() -> void:
	start_new_game(selected_slot)


func select_slot(slot:int):

	selected_slot = slot
	SaveManager.current_save_slot = slot
	print(\"current save slot: \", SaveManager.current_save_slot)

	if SaveManager.save_exists(slot):
		$OverwriteDialog.popup_centered()
	else:
		start_new_game(slot)

func start_new_game(slot:int):

	var data = {
		\"player_position\": Vector2(100,100),
		\"flags\": {
			\"neighbor_intro\": 0,
			\"time_of_day\": \"morning\"
		},
		\"inventory\": {
			\"hands\": {},
			\"pockets\": {},
			\"backpack\": {}
		}
	}

	SaveManager.save_game(slot, data)

	get_tree().change_scene_to_file(\"res://main.tscn\")
"

