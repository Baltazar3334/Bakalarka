resource_name = "MainMenuV3Script"
script/source = "extends Control

@onready var tree: Tree = $MarginContainer/VBoxContainer/HBoxContainer/LeftPanel/VBoxContainer/Tree
@onready var content_editor: TextEdit = $MarginContainer/VBoxContainer/HBoxContainer/RightPanel/HBoxContainer/ContentEditor
@onready var command_output: RichTextLabel = $MarginContainer/VBoxContainer/CommandPanel/VBoxContainer/CommandOutput
@onready var command_input: LineEdit = $MarginContainer/VBoxContainer/CommandPanel/VBoxContainer/CommandInput
@onready var line_numbers: Label = $MarginContainer/VBoxContainer/HBoxContainer/RightPanel/HBoxContainer/Label
@onready var popupDialog: Control = $Popups/PausePopup


# content editor variables
var current_open_file_path: Array = []
var is_insert_mode := false
var file_modified := false

#game load\\save variables
var selected_slot := -1
var pending_action := \"\"

#player file system
var file_system = {}
const PLAYER_FILESYSTEM_PATH = \"user://menu_filesystem.json\"

#pregenerated files system
var default_file_system = {
	\"saves\": {
		\"slot_1.load\": {
			\"type\": \"action\",
			\"action\": \"load_slot_1\",
			\"description\": \"Load save slot 1.\"
		},
		\"slot_2.load\": {
			\"type\": \"action\",
			\"action\": \"load_slot_2\",
			\"description\": \"Load save slot 2.\"
		},
		\"slot_3.load\": {
			\"type\": \"action\",
			\"action\": \"load_slot_3\",
			\"description\": \"Load save slot 3.\"
		},
		\"slot_1.new\": {
			\"type\": \"action\",
			\"action\": \"new_slot_1\",
			\"description\": \"Start new game in slot 1.\"
		},
		\"slot_2.new\": {
			\"type\": \"action\",
			\"action\": \"new_slot_2\",
			\"description\": \"Start new game in slot 2.\"
		},
		\"slot_3.new\": {
			\"type\": \"action\",
			\"action\": \"new_slot_3\",
			\"description\": \"Start new game in slot 3.\"
		}
	},
	\"lore\": {
		\"world.txt\": {
			\"type\": \"text\",
			\"content\": \"Long ago...\"
		},
		\"characters.txt\": {
			\"type\": \"text\",
			\"content\": \"Main cast...\"
		}
	},
	\"new_game.exe\": {
		\"type\": \"action\",
		\"action\": \"new_game\",
		\"description\": \"Create a new game in a save slot.\"
	},
	\"continue.exe\": {
		\"type\": \"action\",
		\"action\": \"load_game\",
		\"description\": \"Load an existing save slot.\"
	},
	\"settings.txt\": {
		\"type\": \"text\",
		\"content\": \"SETTINGS\\nnot implemented yet.\"
	},
	\"controls.txt\": {
		\"type\": \"text\",
		\"content\": \"CONTROLS\\n\\nWASD - move\\nE - interact\\nESC - pause\"
	},
	\"credits.txt\": {
		\"type\": \"text\",
		\"content\": \"Created by Michal Hlavac as a part of his Bachelors degree at the University of Zilina.
		\\nThanks for playing.\"
	},
	\"exit.exe\": {
		\"type\": \"action\",
		\"action\": \"quit\",
		\"description\": \"Exit the game.\"
	}
}


func _ready():
	load_or_create_player_file_system()
	
	setup_tree()
	setup_command_line()
	setup_editor()
	show_welcome_text()

	tree.item_selected.connect(_on_tree_item_selected)
	tree.item_activated.connect(_on_tree_item_activated)

	command_input.text_submitted.connect(_on_command_submitted)
	popupDialog.confirmed.connect(_on_overwrite_dialog_confirmed)
	popupDialog.cancelled.connect(_on_overwrite_dialog_cancelled)
	
	content_editor.add_theme_font_size_override(\"font_size\", 16)

func _unhandled_input(event):
	if current_open_file_path.is_empty():
		return
	
	if event is InputEventKey and event.pressed and not event.echo:
		
		# INSERT MODE → ESC
		if is_insert_mode:
			if event.keycode == KEY_ESCAPE:
				exit_insert_mode()
				get_viewport().set_input_as_handled()
			return
		
		# NORMAL MODE → i
		if event.keycode == KEY_I:
			enter_insert_mode()
			get_viewport().set_input_as_handled()




#READ AND BUILD FUNCTIONS
#******************************************************
func load_or_create_player_file_system():
	if FileAccess.file_exists(PLAYER_FILESYSTEM_PATH):
		var file = FileAccess.open(PLAYER_FILESYSTEM_PATH, FileAccess.READ)
		
		if file != null:
			var text = file.get_as_text()
			file.close()
			
			var parsed = JSON.parse_string(text)
			
			if is_valid_file_system(parsed):
				file_system = parsed
				print(\"Player file system loaded.\")
				return
			else:
				print(\"Player file system is invalid. Creating new one from default.\")
		else:
			print(\"Failed to open player file system. Creating new one from default.\")
	else:
		print(\"Player file system not found. Creating new one from default.\")
	
	file_system = deep_copy_dict(default_file_system)
	save_player_file_system()

func deep_copy_dict(data: Dictionary) -> Dictionary:
	var result = {}
	
	for key in data.keys():
		var value = data[key]
		
		if value is Dictionary:
			result[key] = deep_copy_dict(value)
		elif value is Array:
			result[key] = value.duplicate(true)
		else:
			result[key] = value
	
	return result

func setup_tree():
	tree.clear()
	tree.hide_root = true
	
	var root = tree.create_item()
	build_tree(root, file_system, [])

func build_tree(parent: TreeItem, data: Dictionary, path: Array):
	var keys = data.keys()

	keys.sort_custom(func(a, b):
		var ta = get_type_order(data[a])
		var tb = get_type_order(data[b])
		
		if ta == tb:
			return a < b
		
		return ta < tb
	)

	for key in keys:
		var item = tree.create_item(parent)
		
		var current_path = path.duplicate()
		current_path.append(key)
		item.set_metadata(0, current_path)
		
		var value = data[key]
		
		if value is Dictionary and not value.has(\"type\"):
			item.set_text(0,\"\\uf07b \" + key)
			item.set_custom_color(0, Color(\"548FA2\"))
			item.collapsed = true
			build_tree(item, value, current_path)
		
		elif value[\"type\"] == \"text\":
			item.set_text(0,\"\\udb80\\udf9e \" + key)
			item.set_custom_color(0, Color(\"8676B9\"))
		
		elif value[\"type\"] == \"action\":
			item.set_text(0,\"\\uf013 \" + key)
			item.set_custom_color(0, Color(\"A5A8B0\"))

func reset_player_file_system():
	file_system = deep_copy_dict(default_file_system)
	save_player_file_system()
	
	current_open_file_path.clear()
	content_editor.text = \"\"
	content_editor.editable = false
	is_insert_mode = false
	file_modified = false
	set_line_numbers_visible(false)
	command_input.grab_focus()
	
	setup_tree()
	append_command_output(\"Player file system reset to default.\")

func get_type_order(v):
	if v is Dictionary and not v.has(\"type\"):
		return 0 # folder
	elif v[\"type\"] == \"action\":
		return 1 # exe
	elif v[\"type\"] == \"text\":
		return 2 # txt
	return 3

func setup_command_line():
	command_output.clear()
	command_output.append_text(\"> type 'help' for available commands\\n\")
	command_input.placeholder_text = \"enter command...\"

func setup_editor():
	content_editor.editable = false
	content_editor.wrap_mode = content_editor.LINE_WRAPPING_BOUNDARY
	content_editor.text = \"\"
	content_editor.placeholder_text = \"Open a text file to view it.\"
	content_editor.text_changed.connect(_on_editor_text_changed)
	content_editor.caret_blink = true

func show_welcome_text():
	content_editor.text = \"\"\"Nmenu V4 initialised

Welcome to my launcher.

Select a file from the tree on the left.
Double click action files to execute them.
Text files will open on the right.
Type help into the command input for actions.
You can use the command input for quick control of the menu.
Dont forget to have fun while playing!

\"\"\"
	content_editor.editable = false
	current_open_file_path.clear()
	is_insert_mode = false
	file_modified = false
#******************************************************

#DIRECTORY MANAGEMENT FUNCTIONS
#******************************************************
#query
func get_data_by_path(path: Array):
	var current = file_system
	
	for part in path:
		if current.has(part):
			current = current[part]
		else:
			return null
	
	return current

func find_item_by_name(item_name: String, data: Dictionary):
	for key in data.keys():
		if key == item_name:
			return data[key]
		
		if data[key] is Dictionary and not data[key].has(\"type\"):
			var result = find_item_by_name(item_name, data[key])
			if result != null:
				return result
	
	return null

func find_item_path_by_name(item_name: String, data: Dictionary, current_path: Array) -> Array:
	for key in data.keys():
		var new_path = current_path.duplicate()
		new_path.append(key)
		
		if key == item_name:
			return new_path
		
		if data[key] is Dictionary and not data[key].has(\"type\"):
			var result = find_item_path_by_name(item_name, data[key], new_path)
			if not result.is_empty():
				return result
	
	return []

func show_directory(data: Dictionary, depth: int):
	for key in data.keys():
		var prefix = \"\"
		for i in range(depth):
			prefix += \"  \"
		
		append_command_output(prefix + key)
		
		if data[key] is Dictionary and not data[key].has(\"type\"):
			show_directory(data[key], depth + 1)

func get_directory_by_path(path: Array):
	var current = file_system
	
	for part in path:
		if not (current is Dictionary):
			return null
		
		if not current.has(part):
			return null
		
		current = current[part]
		
		if current is Dictionary and current.has(\"type\"):
			return null
	
	return current

func is_valid_file_system(data) -> bool:
	if not (data is Dictionary):
		return false
	
	for key in data.keys():
		var value = data[key]
		
		if not (value is Dictionary):
			return false
		
		if value.has(\"type\"):
			if value[\"type\"] != \"text\" and value[\"type\"] != \"action\":
				return false
			
			if value[\"type\"] == \"text\" and not value.has(\"content\"):
				return false
			
			if value[\"type\"] == \"action\" and not value.has(\"action\"):
				return false
		else:
			if not is_valid_file_system(value):
				return false
	
	return true

func split_virtual_path(path_text: String) -> Array:
	var trimmed = path_text.strip_edges()
	if trimmed.is_empty():
		return []
	
	var parts = trimmed.split(\"/\", false)
	var result: Array = []
	
	for part in parts:
		var clean = String(part).strip_edges()
		if not clean.is_empty():
			result.append(clean)
	
	return result

func get_parent_directory_for_path(path: Array):
	if path.is_empty():
		return null
	
	var parent_path = path.slice(0, path.size() - 1)
	
	if parent_path.is_empty():
		return file_system
	
	return get_directory_by_path(parent_path)

func get_parent_directory_of_existing_path(path: Array):
	if path.is_empty():
		return null
	
	var parent_path = path.slice(0, path.size() - 1)
	
	if parent_path.is_empty():
		return file_system
	
	return get_directory_by_path(parent_path)

func get_name_from_path(path: Array) -> String:
	if path.is_empty():
		return \"\"
	return String(path[path.size() - 1])

func is_subpath(parent_path: Array, child_path: Array) -> bool:
	if child_path.size() < parent_path.size():
		return false
	
	for i in range(parent_path.size()):
		if parent_path[i] != child_path[i]:
			return false
	
	return true


#interaction
func _on_tree_item_selected():
	var item = tree.get_selected()
	if item == null:
		return
	
	var path = item.get_metadata(0)
	var data = get_data_by_path(path)
	
	if data == null:
		return
	
	#folder
	if data is Dictionary and not data.has(\"type\"):
		content_editor.text = \"Folder: \" + \"/\".join(path)
		content_editor.editable = false
		set_line_numbers_visible(false)
		return
	#text file
	if data[\"type\"] == \"text\":
		open_text_file(path, data[\"content\"])
		set_line_numbers_visible(true)
	#executable
	elif data[\"type\"] == \"action\":
		content_editor.text = \"[ACTION FILE]\\n\\n\" + item.get_text(0) + \"\\n\\n\" + data[\"description\"] + \"\\n\\nDouble click to execute.\"
		content_editor.editable = false
		current_open_file_path.clear()
		is_insert_mode = false
		file_modified = false
		set_line_numbers_visible(false)

func _on_tree_item_activated():
	var item = tree.get_selected()
	if item == null:
		return
	
	var path = item.get_metadata(0)
	var data = get_data_by_path(path)
	
	if data == null:
		return
	
	# folder
	if data is Dictionary and not data.has(\"type\"):
		item.collapsed = !item.collapsed
		return
	
	# text file
	if data[\"type\"] == \"text\":
		open_text_file(path, data[\"content\"])
		return
	
	# action file
	if data[\"type\"] == \"action\":
		run_action(data[\"action\"])

func save_player_file_system():
	var file = FileAccess.open(PLAYER_FILESYSTEM_PATH, FileAccess.WRITE)
	if file == null:
		append_command_output(\"Failed to save player file system.\")
		return
	
	file.store_string(JSON.stringify(file_system, \"\\t\"))
	file.close()

func create_directory(path: Array) -> bool:
	if path.is_empty():
		return false
	
	var dir_name = String(path[path.size() - 1])
	if not is_valid_fs_name(dir_name):
		return false
	
	var parent = get_parent_directory_for_path(path)
	if parent == null:
		return false
	
	if parent.has(dir_name):
		return false
	
	parent[dir_name] = {}
	save_player_file_system()
	setup_tree()
	return true

func move_item(source_path: Array, destination_path: Array) -> bool:
	if source_path.is_empty() or destination_path.is_empty():
		return false
	
	if source_path.size() == 1 and source_path[0] == \"saves\":
		return false
	
	if destination_path.size() >= 1 and destination_path[0] == \"saves\":
		return false
	
	var source_name = get_name_from_path(source_path)
	var destination_name = get_name_from_path(destination_path)
	
	if not is_valid_fs_name(destination_name):
		return false
	
	var source_parent = get_parent_directory_of_existing_path(source_path)
	var destination_parent = get_parent_directory_for_path(destination_path)
	
	if source_parent == null or destination_parent == null:
		return false
	
	if not source_parent.has(source_name):
		return false
	
	var item = source_parent[source_name]
	
	if item is Dictionary and item.has(\"type\") and item[\"type\"] == \"action\":
		return false
	
	if destination_parent.has(destination_name):
		return false
	
	if item is Dictionary and not item.has(\"type\"):
		var destination_parent_path = destination_path.slice(0, destination_path.size() - 1)
		
		if is_subpath(source_path, destination_parent_path):
			return false
	
	if source_path == destination_path:
		return false
	
	destination_parent[destination_name] = item
	source_parent.erase(source_name)
	
	remap_open_path_after_move(source_path, destination_path)
	
	save_player_file_system()
	setup_tree()
	return true

func remap_open_path_after_move(source_path: Array, destination_path: Array):
	if current_open_file_path.is_empty():
		return
	
	# presne ten istý item
	if current_open_file_path == source_path:
		current_open_file_path = destination_path.duplicate()
		return
	
	# ak sa presúval priečinok a otvorený súbor bol v ňom
	if is_subpath(source_path, current_open_file_path):
		var suffix = current_open_file_path.slice(source_path.size())
		current_open_file_path = destination_path.duplicate()
		current_open_file_path.append_array(suffix)

func delete_directory(path: Array) -> bool:
	if path.is_empty():
		return false
	
	var dir_name = path[path.size() - 1]
	var parent_path = path.slice(0, path.size() - 1)
	var parent = file_system if parent_path.is_empty() else get_directory_by_path(parent_path)
	
	if parent == null:
		return false
	
	if not parent.has(dir_name):
		return false
	
	var data = parent[dir_name]
	
	if not (data is Dictionary):
		return false
	
	if data.has(\"type\"):
		return false
	
	if not data.is_empty():
		return false
	
	parent.erase(dir_name)
	save_player_file_system()
	setup_tree()
	return true

func create_text_file(path: Array, content: String = \"\") -> bool:
	if path.is_empty():
		return false
	
	var file_name = String(path[path.size() - 1])
	if not is_valid_fs_name(file_name):
		return false
	
	if not file_name.ends_with(\".txt\"):
		return false
	
	var parent = get_parent_directory_for_path(path)
	if parent == null:
		return false
	
	if parent.has(file_name):
		return false
	
	parent[file_name] = {
		\"type\": \"text\",
		\"content\": content
	}
	
	save_player_file_system()
	setup_tree()
	return true

func open_text_file(path: Array, text: String):
	current_open_file_path = path.duplicate()
	content_editor.text = text
	update_line_numbers()
	
	content_editor.editable = false
	is_insert_mode = false
	file_modified = false
	append_command_output(\"Opened: \" + \"/\".join(path))
	append_command_output(\"-- NORMAL MODE --\")

func delete_target(parts: Array):
	if parts.size() < 2:
		append_command_output(\"Usage: delete save 1|2|3 OR delete file.txt\")
		return
	
	
	if parts[1].to_lower() == \"save\":
		if parts.size() < 3:
			append_command_output(\"Usage: delete save 1|2|3\")
			return
		
		var slot = int(parts[2])
		if slot < 1 or slot > 3:
			append_command_output(\"Invalid save slot. Use 1, 2 or 3.\")
			return
		
		delete_save_slot(slot)
		return
	
	# delete lore/file.txt alebo delete file.txt
	var path_text = parts[1]
	delete_virtual_file(path_text)

func delete_virtual_file(path_text: String):
	if path_text.is_empty():
		append_command_output(\"Invalid file path.\")
		return
	
	if path_text[0] == \"saves\":
		append_command_output(\"Cannot delete system directory: saves\")
		return
	
	var path = path_text.split(\"/\")
	if path.is_empty():
		append_command_output(\"Invalid file path.\")
		return
	
	var data = get_data_by_path(path)
	if data == null:
		append_command_output(\"File not found: \" + path_text)
		return
	
	# folder
	if data is Dictionary and not data.has(\"type\"):
		if delete_directory(path):
			append_command_output(\"Deleted directory: \" + path_text)
		else:
			append_command_output(\"Directory is not empty or cannot be deleted: \" + path_text)
		return
	
	if not (data is Dictionary and data.has(\"type\")):
		append_command_output(\"Invalid file type.\")
		return
	
	match data[\"type\"]:
		\"text\":
			if delete_text_file(path):
				append_command_output(\"Deleted file: \" + path_text)
			else:
				append_command_output(\"Failed to delete file: \" + path_text)
		
		\"action\":
			append_command_output(\"Executable files cannot be deleted.\")
		
		_:
			append_command_output(\"Unsupported file type.\")

func delete_text_file(path: Array) -> bool:
	if path.is_empty():
		return false
	
	var file_name = path[path.size() - 1]
	var parent_path = path.slice(0, path.size() - 1)
	var parent = file_system if parent_path.is_empty() else get_directory_by_path(parent_path)
	
	if parent == null:
		return false
	
	if not parent.has(file_name):
		return false
	
	var data = parent[file_name]
	
	if not (data is Dictionary and data.has(\"type\")):
		return false
	
	if data[\"type\"] != \"text\":
		return false
	
	parent.erase(file_name)
	
	if current_open_file_path == path:
		current_open_file_path.clear()
		content_editor.text = \"\"
		content_editor.editable = false
		is_insert_mode = false
		file_modified = false
		set_line_numbers_visible(false)
		command_input.grab_focus()
	
	save_player_file_system()
	setup_tree()
	return true
	
func close_current_file(force := false):
	if current_open_file_path.is_empty():
		append_command_output(\"No file opened.\")
		return
	
	if is_insert_mode:
		append_command_output(\"Leave insert mode first with 'esc'.\")
		return
	
	if file_modified and not force:
		append_command_output(\"No write since last change.\")
		append_command_output(\"Use :w, :wq or :q!\")
		return
	
	current_open_file_path.clear()
	content_editor.text = \"\"
	content_editor.editable = false
	is_insert_mode = false
	file_modified = false
	append_command_output(\"File closed.\")

func save_current_file():
	if current_open_file_path.is_empty():
		append_command_output(\"No file opened.\")
		return
	
	var data = get_data_by_path(current_open_file_path)
	if data == null:
		append_command_output(\"Invalid file path.\")
		return
	
	if data is Dictionary and data.has(\"type\") and data[\"type\"] == \"text\":
		data[\"content\"] = content_editor.text
		save_player_file_system()
		
		file_modified = false
		append_command_output(\"Written: \" + \"/\".join(current_open_file_path))
	else:
		append_command_output(\"Current file is not writable.\")

func open_file_by_name(file_name: String):
	var path = find_item_path_by_name(file_name, file_system, [])
	if path.is_empty():
		append_command_output(\"File not found: \" + file_name)
		return
	
	var data = get_data_by_path(path)
	if data == null:
		append_command_output(\"File not found: \" + file_name)
		return
	
	if data is Dictionary and data.has(\"type\") and data[\"type\"] == \"text\":
		open_text_file(path, data[\"content\"])
	else:
		append_command_output(file_name + \" is not a text file.\")

func run_file_by_name(file_name: String):
	var data = find_item_by_name(file_name, file_system)
	if data == null:
		append_command_output(\"File not found: \" + file_name)
		return
	
	if data is Dictionary and data.has(\"type\") and data[\"type\"] == \"action\":
		append_command_output(\"Executing \" + file_name)
		run_action(data[\"action\"])
	else:
		append_command_output(file_name + \" is not executable.\")
#******************************************************



#EXE RUN HANDLERS
#******************************************************
func run_action(action_name: String):
	match action_name:
		\"new_game\":
			start_new_game()
		\"load_game\":
			load_game()
		\"new_slot_1\":
			start_new_game_in_slot(1)
		\"new_slot_2\":
			start_new_game_in_slot(2)
		\"new_slot_3\":
			start_new_game_in_slot(3)
		\"load_slot_1\":
			load_game_from_slot(1)
		\"load_slot_2\":
			load_game_from_slot(2)
		\"load_slot_3\":
			load_game_from_slot(3)
		\"quit\":
			quit_game()

func start_new_game():
	content_editor.text = \"\"\"NEW GAME

Choose a save slot.

You can:
- open saves/slot_1.new
- open saves/slot_2.new
- open saves/slot_3.new

Or use command line:
new 1
new 2
new 3\"\"\"
	content_editor.editable = false

func load_game():
	content_editor.text = \"\"\"LOAD GAME
	Available commands:
	load 1
	load 2
	load 3
	
	\"\"\" + get_save_status_text()
	content_editor.editable = false

func quit_game():
	get_tree().quit()
#******************************************************



#EVERYTHING SAVE AND LOAD OF .save FILES (SaveManager utilisation not local saves)
#******************************************************
func get_save_status_text() -> String:
	var text = \"SAVE STATUS\\n\\n\"
	for i in range(1, 4):
		text += \"Slot %d: %s\\n\" % [i, \"USED\" if SaveManager.save_exists(i) else \"EMPTY\"]
	return text

func start_new_game_in_slot(slot: int):
	selected_slot = slot
	SaveManager.current_save_slot = slot
	
	if SaveManager.save_exists(slot):
		pending_action = \"new_game\"
		overwriteDialogPopup()
	else:
		create_new_save_and_start(slot)

func create_new_save_and_start(slot: int):
	var data = {
		\"player_position\": Vector2(612.6969, 3712.808),
		\"flags\": Global.DEFAULT_FLAGS.duplicate(),
		\"inventory\": {
			\"hands\": {},
			\"pockets\": {},
			\"backpack\": {}
		}
	}
	
	SaveManager.save_game(slot, data)
	append_command_output(\"Created new game in slot %d\" % slot)
	SaveManager.load_game_to_scene(slot, \"res://main.tscn\")

func load_game_from_slot(slot: int):
	if SaveManager.save_exists(slot):
		SaveManager.current_save_slot = slot
		append_command_output(\"Loading slot %d\" % slot)
		SaveManager.load_game_to_scene(slot)
	else:
		content_editor.text = \"Slot %d is empty.\" % slot
		content_editor.editable = false
		append_command_output(\"Cannot load slot %d - empty slot\" % slot)

func delete_save_slot(slot: int):
	if SaveManager.delete_save(slot):
		append_command_output(\"Deleted save in slot %d\" % slot)
	else:
		append_command_output(\"Slot %d is already empty.\" % slot)

func delete_all_saves():
	for slot in range(1, 4):
		SaveManager.delete_save(slot)
	
	append_command_output(\"All save slots deleted.\")
#******************************************************



#TEXT EDITOR FUNCTIONS
#******************************************************
func _on_editor_text_changed():
	if is_insert_mode and current_open_file_path.size() > 0:
		file_modified = true
	update_line_numbers()

func enter_insert_mode():
	if current_open_file_path.is_empty():
		append_command_output(\"No text file opened.\")
		return
	
	var data = get_data_by_path(current_open_file_path)
	if data == null or not (data is Dictionary and data.has(\"type\") and data[\"type\"] == \"text\"):
		append_command_output(\"Current file is not editable.\")
		return
	
	is_insert_mode = true
	content_editor.editable = true
	append_command_output(\"-- INSERT MODE --\")
	
	await get_tree().process_frame
	content_editor.grab_focus()
	content_editor.queue_redraw()

func exit_insert_mode():
	if not is_insert_mode:
		append_command_output(\"Already in normal mode.\")
		return
	
	is_insert_mode = false
	content_editor.editable = false
	command_input.grab_focus()
	append_command_output(\"-- NORMAL MODE --\")

func set_line_numbers_visible(visible: bool):
	line_numbers.visible = visible

func update_line_numbers():
	line_numbers.add_theme_color_override(\"default_color\", Color(0.5, 0.5, 0.5))
	content_editor.add_theme_font_size_override(\"font_size\", 16)
	
	var line_count = content_editor.get_line_count()
	var text = \"\"
	
	for i in range(line_count):
		text += str(i + 1) + \"\\n\"
	
	line_numbers.text = text
#******************************************************



#COMMAND LINE FUNCTIONS
#******************************************************
func _on_command_submitted(command: String):
	parse_command(command)
	command_input.clear()
	await get_tree().process_frame
	command_input.grab_focus()

func is_valid_fs_name(name: String) -> bool:
	var trimmed = name.strip_edges()
	if trimmed.is_empty():
		return false
	
	if trimmed.contains(\"/\"):
		return false
	
	return true

func parse_command(command: String):
	var cmd = command.strip_edges()
	if cmd.is_empty():
		return
	
	append_command_output(\"> \" + cmd)
	
	var parts = cmd.split(\" \", false)
	var base = parts[0].to_lower()
	
	match base:
		\"help\":
			show_help()
		
		\"dir\":
			show_directory(file_system, 0)
		
		\"open\":
			if parts.size() < 2:
				append_command_output(\"Usage: open filename\")
				return
			
			open_file_by_name(parts[1])
		
		\"mkdir\":
			make_directory_command(parts)
		
		\"touch\":
			create_text_file_command(parts)
		
		\"move\":
			move_command(parts)
		
		\"rename\":
			move_command(parts)
		
		\"reset\":
			if parts.size() < 2:
				append_command_output(\"Usage: reset tree or all\")
				return
			
			var target = parts[1].to_lower()
			
			if target == \"tree\":
				request_reset_tree()
			elif target == \"all\":
				request_reset_all()
			else:
				append_command_output(\"Usage: reset tree OR reset all\")
				
		\"delete\":
			delete_target(parts)
	
		\"run\":
			if parts.size() < 2:
				append_command_output(\"Usage: run file.exe\")
				return
			
			run_file_by_name(parts[1])
		
		\"i\":
			enter_insert_mode()
		
		\"esc\":
			exit_insert_mode()
		
		\":w\":
			save_current_file()
		
		\":q\":
			close_current_file(false)
		
		\":q!\":
			close_current_file(true)
		
		\":wq\":
			save_current_file()
			close_current_file(true)
		
		\":wqa\":
			save_current_file()
			close_current_file(true)
		
		\"new\":
			if parts.size() < 2:
				append_command_output(\"Usage: new 1|2|3\")
				return
			
			var slot = int(parts[1])
			if slot >= 1 and slot <= 3:
				start_new_game_in_slot(slot)
			else:
				append_command_output(\"Invalid slot. Use 1, 2 or 3.\")
		
		\"load\":
			if parts.size() < 2:
				append_command_output(\"Usage: load 1|2|3\")
				return
			
			var slot = int(parts[1])
			if slot >= 1 and slot <= 3:
				load_game_from_slot(slot)
			else:
				append_command_output(\"Invalid slot. Use 1, 2 or 3.\")
		
		\"quit\", \"exit\":
			quit_game()
		
		\"clear\":
			command_output.clear()
		
		_:
			append_command_output(\"Unknown command. Type 'help'.\")

func make_directory_command(parts: Array):
	if parts.size() < 2:
		append_command_output(\"Usage: mkdir folder_name or mkdir path/folder_name\")
		return
	
	var path = split_virtual_path(parts[1])
	if path.is_empty():
		append_command_output(\"Invalid directory path.\")
		return
	
	if create_directory(path):
		append_command_output(\"Directory created: \" + \"/\".join(path))
	else:
		append_command_output(\"Failed to create directory: \" + parts[1])

func create_text_file_command(parts: Array):
	if parts.size() < 2:
		append_command_output(\"Usage: touch file.txt or touch path/file.txt\")
		return
	
	var path = split_virtual_path(parts[1])
	if path.is_empty():
		append_command_output(\"Invalid file path.\")
		return
	
	var file_name = path[path.size() - 1]
	if not file_name.ends_with(\".txt\"):
		append_command_output(\"Only .txt files can be created.\")
		return
	
	if create_text_file(path, \"\"):
		append_command_output(\"File created: \" + \"/\".join(path))
		open_text_file(path, \"\")
		set_line_numbers_visible(true)
	else:
		append_command_output(\"Failed to create file: \" + parts[1])

func move_command(parts: Array):
	if parts.size() < 3:
		append_command_output(\"Usage: move source_path destination_path\")
		return
	
	var source_path = split_virtual_path(parts[1])
	var destination_path = split_virtual_path(parts[2])
	
	if source_path.is_empty() or destination_path.is_empty():
		append_command_output(\"Invalid path.\")
		return
	
	var source_data = get_data_by_path(source_path)
	if source_data == null:
		append_command_output(\"Source not found: \" + parts[1])
		return
	
	if move_item(source_path, destination_path):
		append_command_output(\"Moved: \" + parts[1] + \" -> \" + parts[2])
	else:
		append_command_output(\"Failed to move: \" + parts[1] + \" -> \" + parts[2])

func show_help():
	append_command_output(\"Available commands:\")
	append_command_output(\"help                 - show help\")
	append_command_output(\"dir                  - show file tree\")
	append_command_output(\"open FILE            - open text file\")
	append_command_output(\"run FILE             - run action file\")
	append_command_output(\"i                    - enter insert mode for opened text file\")
	append_command_output(\"esc                  - leave insert mode\")
	append_command_output(\":w                   - save current file\")
	append_command_output(\":q                   - close current file\")
	append_command_output(\":q!                  - force close current file\")
	append_command_output(\":wq                  - save and close current file\")
	append_command_output(\":wqa                 - save and close current file\")
	append_command_output(\"new 1|2|3            - create new game in slot\")
	append_command_output(\"load 1|2|3           - load game from slot\")
	append_command_output(\"delete save 1|2|3    - delete save slot\")
	append_command_output(\"delete FILE.txt      - delete text file\")
	append_command_output(\"delete path/FILE.txt - delete text file by path\")
	append_command_output(\"clear                - clear command output\")
	append_command_output(\"quit                 - exit game\")
	append_command_output(\"reset tree           - reset menu file system to default\")
	append_command_output(\"reset all            - reset menu file system and delete all saves\")
	append_command_output(\"delete DIR           - delete empty directory\")
	append_command_output(\"delete FILE.txt      - delete text file\")
	append_command_output(\"delete path/item     - delete empty directory or text file by path\")
	append_command_output(\"touch path/FILE.txt  - create text file by path\")
	append_command_output(\"move SRC DST         - move/rename text file or directory\")
	append_command_output(\"rename SRC DST       - alias for move\")

func append_command_output(text: String):
	command_output.append_text(text + \"\\n\")
	await get_tree().process_frame
	command_output.scroll_to_line(command_output.get_line_count())
	command_input.grab_focus()
#******************************************************



#POPUP FUNCTIONS
#******************************************************
func overwriteDialogPopup():
	popupDialog.open(\"Overwrite selected save slot?\")
	
func _on_overwrite_dialog_confirmed():
	match pending_action:
		\"new_game\":
			if selected_slot != -1:
				popupDialog.close()
				create_new_save_and_start(selected_slot)
		
		\"reset_tree\":
			popupDialog.close()
			reset_player_file_system()
		
		\"reset_all\":
			popupDialog.close()
			delete_all_saves()
			reset_player_file_system()
	
	pending_action = \"\"
	selected_slot = -1
	
func _on_overwrite_dialog_cancelled():
	pending_action = \"\"
	selected_slot = -1

func request_reset_tree():
	pending_action = \"reset_tree\"
	popupDialog.open(\"Reset menu file system to default?\")
	
func request_reset_all():
	pending_action = \"reset_all\"
	popupDialog.open(\"Reset menu file system and delete all saves?\")
#******************************************************
"

