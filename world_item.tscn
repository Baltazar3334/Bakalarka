[sub_resource type="GDScript" id="GDScript_wmkq7"]
resource_name = "worldItemScript"
script/source = "extends Area2D

@onready var sprite: Sprite2D = $Sprite2D

var item_name: String = \"\"
var amount: int = 1

func _ready():
	add_to_group(\"world_items\")
	update_sprite()
	scale = Vector2(0.8, 0.8)
	z_index = 15


func update_sprite():
	var path = \"res://assets/items/%s.png\" % item_name
	
	if ResourceLoader.exists(path):
		sprite.texture = load(path)
	else:
		sprite.texture = load(\"res://assets/items/default.png\")

func get_save_data() -> Dictionary:
	return {
		\"item_name\": item_name,
		\"amount\": amount,
		\"x\": global_position.x,
		\"y\": global_position.y
	}
"

