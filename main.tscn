[sub_resource type="GDScript" id="GDScript_34ol3"]
resource_name = "ItemMoverArea"
script/source = "extends Area2D

@export var speed := 20.0

var items_inside = []

func _on_area_entered(area):
	if area.is_in_group(\"world_items\") \\
	or area.is_in_group(\"world_items_static\"):

		items_inside.append(area)

func _on_area_exited(area):
	items_inside.erase(area)

func _process(delta):
	for item in items_inside:
		if !is_instance_valid(item):
			continue
		item.global_position.y -= speed * delta
"

