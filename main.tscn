[sub_resource type="GDScript" id="GDScript_074og"]
resource_name = "Dialog"
script/source = "extends TextureRect

@onready var label: RichTextLabel = $Label
@onready var player = $\"../../player\"
@onready var choices_box = $Choices

var dialogs := {}
var current_dialog := {}
var lines: Array = []
var line_index := 0

var player_choosing: bool = false
var choices: Array = []
var selected_choice := 0

var is_open := false

var changes_applying = false

signal dialog_closed


func _ready():
	visible = false
	load_dialogs()


func load_dialogs():
	dialogs.clear()

	var dir = DirAccess.open(\"res://assets/dialog/\")
	if dir == null:
		print(\"Dialog folder not found!\")
		return

	dir.list_dir_begin()
	var file_name = dir.get_next()

	while file_name != \"\":
		if file_name.ends_with(\".json\"):
			var path = \"res://assets/dialog/\" + file_name
			print(\"Loading dialog file:\", path)

			var file = FileAccess.open(path, FileAccess.READ)
			if file:
				var data = JSON.parse_string(file.get_as_text())
				file.close()

				if data is Dictionary:
					for key in data.keys():
						if dialogs.has(key):
							print(\"WARNING: duplicate dialog key:\", key)
						dialogs[key] = data[key]
				else:
					print(\"Invalid JSON in:\", path)

		file_name = dir.get_next()

	dir.list_dir_end()


func open_dialog(key: String):
	var selected_dialog_key := \"\"
	
	if !dialogs.has(key):
		push_warning(\"Dialog not found: \" + key)
		return
	print(\"zaciatok dialogu\")
	print(key)
	var dialog_entry = dialogs[key]
	print(dialog_entry.has(\"conditions\"))
	#conditons checker
	if dialog_entry.has(\"conditions\"):
		for condition in dialog_entry[\"conditions\"]:
			print(\"testujem condition\")
			print(condition)
			var all_match = true
			#flags
			if condition.has(\"flags\"):
				for flag_name in condition[\"flags\"].keys():
					var required_value = condition[\"flags\"][flag_name]
					if player.flags.get(flag_name) != required_value:
						all_match = false
						break
			# flag compare
			if all_match and condition.has(\"flag_compare\"):
				for compare in condition[\"flag_compare\"]:
					var current = player.flags.get(compare[\"flag\"], 0)
					var wanted = compare[\"value\"]
					match compare[\"operator\"]:
						\">\":
							all_match = current > wanted
						\">=\":
							all_match = current >= wanted
						\"<\":
							all_match = current < wanted
						\"<=\":
							all_match = current <= wanted
						\"==\":
							all_match = current == wanted
						\"!=\":
							all_match = current != wanted
			#required items
			if all_match and condition.has(\"requires_item\"):
				var item_data = condition[\"requires_item\"]
				var item_name = item_data[\"name\"]
				var amount = item_data.get(\"amount\", 1)
				if not InventoryManager.has_item(item_name, amount):
					all_match = false
			if condition.has(\"container_items\"):
				for item_data in condition[\"container_items\"]:
					if not InventoryManager.is_item_in_container(
						item_data[\"item\"],
						item_data[\"container\"]
					):
						all_match = false
						break
			#final check for conditions
			if all_match:
					selected_dialog_key = condition.get(\"dialog\", \"\")
					break


		if selected_dialog_key == \"\":
			print(\"dialog key je prazdny\")
			return 
		if !dialogs.has(selected_dialog_key):
			push_warning(\"nenasiel sa vhodny dialog key v dialogoch\" + selected_dialog_key)
			return
		print(\"vybrany dialog:\", selected_dialog_key)
		current_dialog = dialogs[selected_dialog_key]
	else:
		print(\"dialog nema conditions\")
		current_dialog = dialogs[key]
		
	lines = current_dialog.get(\"lines\", []).duplicate(true)
	line_index = 0

	choices.clear()
	selected_choice = 0

	is_open = true
	visible = true
	player.can_move = false
	choices_box.visible = false

	next_line()

func next_line():
	if changes_applying:
		print(\"changes are applying wait for interact input\")
		return
		
	player_choosing = false
	if line_index < lines.size():
		show_line()
		line_index += 1
	else:
		if current_dialog.has(\"choices\"):
			show_choices()
		else: 
			close_dialog()
		
	

func replace_variables(text: String) -> String:

	for flag_name in player.flags.keys():
		text = text.replace(
			\"{\" + flag_name + \"}\",
			str(player.flags[flag_name])
		)

	return text

func show_line():
	var line_data: Dictionary = lines[line_index]

	var speaker: String = line_data.get(\"speaker\", \"\")
	var text: String = line_data.get(\"text\", \"\")
	text = replace_variables(text)

	label.bbcode_text = highlight_speaker_text(speaker, text)

func show_choices():
	var all_choices = current_dialog.get(\"choices\", []).duplicate(true)
	choices.clear()

	for choice in all_choices:
		if is_choice_available(choice):
			choices.append(choice)

	var labels = choices_box.get_children()
	
	for child in labels:
		if child is Label and child.label_settings:
			child.label_settings.font_color = Color.WHITE
	
	player_choosing = true
	selected_choice = 0

	var index := 0
	for child in labels:
		if child is Label:
			if index < choices.size():
				child.text = choices[index][\"text\"]
				child.visible = true
				print(\"Loaded:\", child.text)
				index += 1
			else:
				child.visible = false

	if choices.size() == 0:
		choices_box.visible = false
		close_dialog()
		return

	choices_box.visible = true

	var lbl := labels[selected_choice] as Label
	if lbl != null and lbl.label_settings:
		lbl.label_settings.font_color = Color.html(\"#5A97A6\")
	
	
func next_choice():
	var labels = choices_box.get_children()

	if selected_choice >= 0 and selected_choice < choices.size():
		var old_lbl := labels[selected_choice] as Label
		old_lbl.label_settings.font_color = Color.WHITE

	selected_choice = (selected_choice + 1) % choices.size()

	var new_lbl := labels[selected_choice] as Label
	new_lbl.label_settings.font_color = Color.html(\"#5A97A6\")
	
	
func previous_choice():
	var labels = choices_box.get_children()

	if selected_choice >= 0 and selected_choice < choices.size():
		var old_lbl := labels[selected_choice] as Label
		old_lbl.label_settings.font_color = Color.WHITE

	selected_choice = (selected_choice - 1 + choices.size()) % choices.size()

	var new_lbl := labels[selected_choice] as Label
	new_lbl.label_settings.font_color = Color.html(\"#5A97A6\")

func choose_choice():
	if selected_choice < 0 or selected_choice >= choices.size():
		push_warning(\"Invalid selected_choice\")
		return

	var chosen: Dictionary = choices[selected_choice]
	var next_dialog_value = chosen.get(\"next\", null)

	if next_dialog_value == null:
		push_warning(\"Choice has no 'next' field\")
		close_dialog()
		return

	var next_dialog_id: String = str(next_dialog_value)

	lines.clear()
	choices.clear()
	line_index = 0
	selected_choice = 0
	choices_box.visible = false
	open_dialog(next_dialog_id)
	


func is_choice_available(choice: Dictionary) -> bool:
	if choice.has(\"requires_item\"):
		var item_data = choice[\"requires_item\"]
		var item_name = item_data[\"name\"]
		var amount = item_data.get(\"amount\", 1)

		if not InventoryManager.has_item(item_name, amount):
			return false

	if choice.has(\"requires_flag\"):
		var flag_data = choice[\"requires_flag\"]

		for flag_name in flag_data.keys():
			var required_value = flag_data[flag_name]
			var current_value = player.flags.get(flag_name)

			if current_value != required_value:
				return false

	return true

func close_dialog():
	var next_key := \"\"
	var has_next_dialog := current_dialog.has(\"next_dialog\")

	if has_next_dialog:
		next_key = current_dialog[\"next_dialog\"]
	
	if current_dialog.has(\"on_finish\"):
		changes_applying = true
		var changes = current_dialog[\"on_finish\"]
		
		if changes is Dictionary:
			changes = [changes]
		
		for change in changes:
			
			# FLAGS
			if change.has(\"flag\"):
				var flag_name = change[\"flag\"]
				print(\"Before:\", flag_name, player.flags.get(flag_name))
				
				if change.has(\"toggle\"):
					var options = change[\"toggle\"]
					if player.flags[flag_name] == options[0]:
						player.flags[flag_name] = options[1]
					else:
						player.flags[flag_name] = options[0]
				elif change.has(\"set\"):
					player.flags[flag_name] = change[\"set\"]
				elif change.has(\"increase\"):
					player.flags[flag_name] += change[\"increase\"]
				elif change.has(\"decrease\"):
					player.flags[flag_name] -= change[\"decrease\"]
				print(\"After:\", flag_name, player.flags.get(flag_name))
				
				if flag_name == \"time_of_day\":
					player.set_time_of_day(player.flags[flag_name])
				if flag_name == \"day_of_the_week\":
					player.change_day()
			
			#RESET THE BOX PILES IN THE POST OFFICE
			if change.has(\"factory_reset_box_piles\"):
				var pile1 = get_tree().current_scene.get_node(\"boxes1\")
				pile1.reset_boxes()
				var pile2 = get_tree().current_scene.get_node(\"boxes2\")
				pile2.reset_boxes()
				var pile3 = get_tree().current_scene.get_node(\"boxes3\")
				pile3.reset_boxes()
				pile1.clear_factory_boxes()
			
			if change.has(\"highlight_item\"):
				var item = change[\"highlight_item\"]
				var itemNode = get_tree().current_scene.get_node_or_null(item)
				if itemNode != null:
					HighlightManager.highlight(itemNode, 2.5)
				else:
					push_warning(\"Highlight target not found: \" + item)
			
			# GIVE ITEM
			if change.has(\"give_item\"):
				var item = change[\"give_item\"]
				var amount = item.get(\"amount\", 1)
				if amount is Dictionary:
					var final_amount = 1
					if amount.has(\"value\"):
						final_amount = int(player.flags.get(amount[\"value\"], 0))
					if amount.has(\"multiply_by\"):
						final_amount *= int(player.flags.get(amount[\"multiply_by\"], 1))
					amount = final_amount

				elif amount is String:
					amount = int(player.flags.get(amount, 0))
				InventoryManager.add_item(item[\"name\"], amount)
			
			# REMOVE ITEM
			if change.has(\"remove_item\"):
				var item = change[\"remove_item\"]
				InventoryManager.remove_item(item[\"name\"], item.get(\"amount\", 1))
			
			# MOVE NPC
			if change.has(\"moveNPC\"):
				var moved_entities = []
				var npc_list = change[\"moveNPC\"]
				var marker

				if npc_list is Dictionary:
					npc_list = [npc_list]

				for data in npc_list:
					var NPCid = data[\"NPCid\"]
					var speed = data.get(\"move_speed\", 100)

					var targetEntity = EntityManager.get_entity(NPCid)
					if targetEntity == null:
						print(\"Target NPC not found: \" + NPCid)
						continue

					marker = EntityManager.get_marker(data[\"marker\"])
					if marker == null:
						print(\"Marker not found: \" + data[\"marker\"])
						continue

					if data.has(\"change_after_move\"):
						apply_flags_after_entity_move(targetEntity,data[\"change_after_move\"])
					targetEntity.looking_up = false
					targetEntity.move_to(marker.global_position, speed)
					moved_entities.append({\"entity\": targetEntity,\"marker\": marker})
				
				if has_next_dialog:
					visible = false
					lines.clear()
					choices.clear()
					line_index = 0
					selected_choice = 0
					choices_box.visible = false
				
				for data in moved_entities:
					print(data[\"entity\"].entity_id)
				
				while true:
					var somebody_moving := false
					for data in moved_entities:
						if data[\"entity\"].is_moving:
							somebody_moving = true
							break
						else:
							if data[\"marker\"].facing == \"up\":
								data[\"entity\"].looking_up = true
								data[\"entity\"].update_animation(Vector2.ZERO)
					if !somebody_moving:
						break
					await get_tree().process_frame
				
			# TELEPORT
			if change.has(\"teleport\"):
				var coordinates = change[\"teleport\"]
				
				var x = coordinates[\"x\"]
				var y = coordinates[\"y\"]
				var targetCell: Vector2i = Vector2i(x, y)
				var layer = get_tree().current_scene.get_node(\"LayerInteriorColission\")
				player.teleport(layer, targetCell)
			
			#MENU ENTRIES
			if change.has(\"menu_entry\"):
				var data = change[\"menu_entry\"]

				MenuFileManager.unlock_menu_entry(data[\"id\"],data[\"path\"],data[\"text\"])
			
			# CHOOSE RECAP TRIBUTE
			if change.has(\"choose_student\"):
				var selected = randi_range(1, 7)
				Global.recap_tribute = selected
				ConfigManager.set_config_value(\"school.cfg\",\"recap_tribute\",selected)
			
			#RAISE PERMISSION LEVEL
			if change.has(\"permission_raised\"):
				print(\"PERMISSION RAISING\")
				var target_level = int(change[\"permission_raised\"])
				print(\"global permission\")
				print(Global.permission_level)
				print(\"target permission\")
				print(target_level)
				if Global.permission_level < target_level:
					ConfigManager.unlock_permission_level(target_level)
					player.flags[\"permission_level\"] = target_level
			
			#BACK TO INTRO SCENE
			if change.has(\"restart_game\"):
				SaveManager.perform_quick_save()
				Transitioner.change_scene(\"res://Menus/intro.tscn\",Transitioner.TransitionType.SIMPLE,5.0)
	changes_applying = false
	if has_next_dialog:
		open_dialog(next_key)
		return

	is_open = false
	visible = false
	player.can_move = true
	if player.is_sitting:
		player.is_sitting = false

	lines.clear()
	choices.clear()
	line_index = 0
	selected_choice = 0
	choices_box.visible = false
	EntityManager.refresh_all_entities()
	dialog_closed.emit()
	


func apply_flags_after_entity_move(targetEntity, changes_after_move: Dictionary):
	if targetEntity == null:
		return
	
	if not targetEntity.has_signal(\"move_finished\"):
		print(\"Entity has no move_finished signal\")
		return
	
	targetEntity.move_finished.connect(_on_entity_move_finished.bind(changes_after_move), CONNECT_ONE_SHOT)
	
func _on_entity_move_finished(changes_after_move: Dictionary):
	for flag_name in changes_after_move.keys():
		var new_value = changes_after_move[flag_name]
		player.flags[flag_name] = new_value
		print(\"Flag changed after move:\", flag_name, \"->\", new_value)
	
	EntityManager.refresh_all_entities()



func highlight_speaker_text(speaker: String, text: String) -> String:
	var colors = {
		\"jessie\": \"#5A97A6\", 
		\"neutral\": \"#FFFFFF\",    
		\"neighbor\": \"#6A6D40\",
		\"father\": \"#5b08ae\",
		\"med_lady\": \"#a61414\",
		\"janette\": \"#a8bd4d\",
		\"david\": \"#7ded7b\",
		\"goldie\": \"#ffcd05\",
		\"teacher\": \"#a61414\",
		\"jake\": \"#a8bd4d\",
		
	}

	var color: String = colors.get(speaker, \"#FFFFFF\")

	return \"[color=%s]%s[/color]\" % [color, text]
"

