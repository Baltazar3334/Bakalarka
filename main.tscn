[sub_resource type="GDScript" id="GDScript_getpj"]
resource_name = "PausePopup"
script/source = "extends Control

signal confirmed
signal cancelled

@onready var panel: Panel = $CenterContainer/Panel
@onready var label: Label = $CenterContainer/Panel/VBoxContainer/Label
@onready var yes_button: Button = $CenterContainer/Panel/VBoxContainer/yesButton
@onready var no_button: Button = $CenterContainer/Panel/VBoxContainer/noButton

func _ready():
	hide()
	yes_button.pressed.connect(_on_yes_pressed)
	no_button.pressed.connect(_on_no_pressed)
	style_popup()

func open(text: String):
	label.text = text
	show()
	yes_button.grab_focus()

func close():
	hide()

func _on_yes_pressed():
	hide()
	confirmed.emit()

func _on_no_pressed():
	hide()
	cancelled.emit()
	
func _unhandled_input(event: InputEvent):
	if event.is_action_pressed(\"interact\"):
		if yes_button.has_focus():
			_on_yes_pressed()
		elif no_button.has_focus():
			_on_no_pressed()

func style_popup():
	var panel_style := StyleBoxFlat.new()
	panel_style.bg_color = Color(\"#000000\")
	panel_style.border_color = Color(\"#3f6b74\")
	panel_style.set_border_width_all(2)
	panel_style.content_margin_left = 8
	panel_style.content_margin_top = 8
	panel_style.content_margin_right = 8
	panel_style.content_margin_bottom = 8

	panel.add_theme_stylebox_override(\"panel\", panel_style)

	label.add_theme_color_override(\"font_color\", Color(\"#f2f2f2\"))
"

