[sub_resource type="GDScript" id="GDScript_0xm2m"]
script/source = "extends CharacterBody2D

#STORY FLAGS
var flags := {
	\"neighbor_intro\": 0,
	\"time_of_day\": \"morning\"
}


@export var max_speed := 150.0
@export var acceleration := 800.0
@export var friction := 1000.0

@export var morning_texture: Texture
@export var evening_texture: Texture
@export var transitioner: Transitioner

var loaded_data: Dictionary = {}

@onready var anim = $AnimatedSprite2D
@onready var time_filter: ColorRect = $\"../TimeUI/TimeFilter\"
@onready var time_image: TextureRect = $\"../TimeUI/TimeImage\"
@onready var inventory_ui: Control = $\"../InventoryUI/Inventory\"

@onready var teleport_layers := [
	$\"../LayerColission\",
	$\"../LayerInteriorColission\"
]
@onready var dialog_ui = get_node(\"../DialogUI/TextureRect\")



var can_move := true
var is_teleporting := false

func _ready():
	if SaveManager.loaded_data.size() > 0:
		loaded_data = SaveManager.loaded_data
		_apply_loaded_data()
		call_deferred(\"_try_find_transitioner\")


func _try_find_transitioner():
	transitioner = get_node_or_null(\"../LoadingScreen/Transitioner\")
	if transitioner == null:
		call_deferred(\"_try_find_transitioner\")
	else:
		_on_transitioner_ready(transitioner)

func _on_transitioner_ready(transitioner):
	print(\"Transitioner nájdený!\")

func _apply_loaded_data():
	global_position = loaded_data.get(\"player_position\", global_position)
	flags = loaded_data.get(\"flags\", flags)
	if \"time_of_day\" in flags:
		set_time_of_day(flags[\"time_of_day\"])

func _physics_process(delta):
	if not can_move:
		velocity = Vector2.ZERO
		move_and_slide()
		return
	
	var direction = Vector2.ZERO
	#pohyb
	if Input.is_action_pressed(\"ui_right\"):
		direction.x += 1
	if Input.is_action_pressed(\"ui_left\"):
		direction.x -= 1
	if Input.is_action_pressed(\"ui_down\"):
		direction.y += 1
	if Input.is_action_pressed(\"ui_up\"):
		direction.y -= 1

	direction = direction.normalized()
	if direction != Vector2.ZERO:
		var target_velocity = direction * max_speed
		velocity = velocity.move_toward(target_velocity, acceleration * delta)
	else:
		velocity = velocity.move_toward(Vector2.ZERO, friction * delta)
	
	#animacie
	if direction != Vector2.ZERO:
			if direction.y == -1:
				if anim.animation != \"WalkUp\":
					anim.play(\"walkUp\")
			if direction.y == 1:
				if anim.animation != \"WalkDown\":
					anim.play(\"walkDown\")
			if direction.y == 0:
				if anim.animation != \"WalkDown\":
					anim.play(\"walkDown\")
	else:
		if anim.animation != \"idle\":
			anim.play(\"idle\")
	move_and_slide()


#handler na input \"e\"
func _unhandled_input(event):
	if event.is_action_pressed(\"quick_save\"):
		SaveManager.perform_quick_save()
	
	if event.is_action_pressed(\"inventory\"):
		if !inventory_ui.visible:
			inventory_ui.visible = true
			can_move = false
		else:
			inventory_ui.visible = false
			can_move = true
	
	if dialog_ui.is_open:
		if dialog_ui.player_choosing:
			if event.is_action_pressed(\"ui_up\"):
				dialog_ui.previous_choice()
			if event.is_action_pressed(\"ui_down\"):
				dialog_ui.next_choice()
			if event.is_action_pressed(\"interact\"):
				dialog_ui.choose_choice()
			return
		if event.is_action_pressed(\"interact\"):
			dialog_ui.next_line()
		return

	if event.is_action_pressed(\"interact\"):
		try_teleport_or_dialog()

#handle: teleportacia a dialog
func try_teleport_or_dialog():
	for layer in teleport_layers:
		if layer == null:
			continue

		var cell: Vector2i = layer.local_to_map(
			layer.to_local(global_position)
		)

		var tile_data = layer.get_cell_tile_data(cell)
		if tile_data == null:
			continue

		#teleport ma prednost
		if tile_data.has_custom_data(\"teleport\"):
			if !(tile_data.get_custom_data(\"teleport\") == Vector2i.ZERO):
				await teleport(layer, tile_data)
				return

		if tile_data.has_custom_data(\"dialog_key\"):
			var dialog_key = tile_data.get_custom_data(\"dialog_key\")
			if dialog_key != \"\":
				dialog_ui.open_dialog(dialog_key)
				return


#teleport
func teleport(layer, tile_data):
	if is_teleporting:
		return

	if transitioner == null:
		print(\"Error: Transitioner node not found!\")
		return

	is_teleporting = true
	can_move = false

	transitioner.set_next_animation(true)
	await get_tree().create_timer(0.9).timeout

	var target_cell: Vector2i = tile_data.get_custom_data(\"teleport\")
	var local_pos = layer.map_to_local(target_cell)
	local_pos += Vector2(layer.tile_set.tile_size) / 2.0
	global_position = layer.to_global(local_pos)

	await get_tree().create_timer(0.8).timeout
	transitioner.set_next_animation(false)

	can_move = true
	is_teleporting = false


#zmena casuaw
func set_time_of_day(time: String):
	if transitioner == null:
		print(\"Error: Transitioner node not found!\")
		return
	
	transitioner.set_next_animation(true)
	await get_tree().create_timer(0.9).timeout
	if time == \"morning\":
		time_filter.color = Color(0.006, 0.015, 0.076, 0)
		time_image.texture = morning_texture
	elif time == \"afternoon\":
		time_image.texture = evening_texture
		time_filter.color = Color(0.006, 0.015, 0.076, 0.746)
	time_image.visible = true
	await get_tree().create_timer(0.8).timeout
	transitioner.set_next_animation(false)
	
"

