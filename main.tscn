[sub_resource type="GDScript" id="GDScript_e71vb"]
resource_name = "CarrySprite"
script/source = "extends Sprite2D


func _process(delta):

	var carry = InventoryManager.inventory[\"carry\"]

	if carry.is_empty():
		visible = false
		return

	var item_name = carry.keys()[0]

	visible = true

	var path = \"res://assets/items/%s.png\" % item_name

	if ResourceLoader.exists(path):
		texture = load(path)
"

