[sub_resource type="GDScript" id="GDScript_1u8w0"]
resource_name = "NotificationPopup"
script/source = "extends Control

@onready var notification_rect = $notificationRect
@onready var notification_label = $notification

func _ready():
	visible = false
	
	await get_tree().create_timer(1.0).timeout



func show_notification(text: String):
	notification_label.text = text

	visible = true
	modulate.a = 0.0

	var tween = create_tween()

	tween.tween_property(
		self,
		\"modulate:a\",
		1.0,
		0.25
	)

	await get_tree().create_timer(5.0).timeout

	tween = create_tween()

	tween.tween_property(
		self,
		\"modulate:a\",
		0.0,
		0.25
	)

	await tween.finished

	visible = false


func file_created(path: String):
	show_notification(
		\"[ new content ] \" + path
	)

func file_updated(path: String):
	show_notification(
		\"[ new content ] \" + path
	)
"

