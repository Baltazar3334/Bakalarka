[sub_resource type="GDScript" id="GDScript_557es"]
resource_name = "EnterCheckZone"
script/source = "extends Node2D

var correct_boxes = []
var wrong_boxes = []
var other_items = []

var correct_count := 0
var wrong_count := 0

var playerMain

func _ready():
	playerMain = get_tree().current_scene.get_node_or_null(\"player\")
	pass

func _on_green_zone_area_entered(area: Area2D) -> void:
	check_item(area, \"box green\")


func _on_red_zone_area_entered(area: Area2D) -> void:
	check_item(area, \"box red\")


func _on_blue_zone_area_entered(area: Area2D) -> void:
	check_item(area, \"box blue\")


func check_item(area, expected_box):
	if !(area.is_in_group(\"world_items\") or area.is_in_group(\"world_items_static\")):
		return
	if area.item_name.begins_with(\"box \"):
		if area.item_name == expected_box:
			correct_boxes.append(area)
			if playerMain == null:
				return
			correct_count += 1
			playerMain.flags[\"factory_successful_boxes\"] = correct_count
		else:
			wrong_boxes.append(area)
			wrong_count += 1
	else:
		other_items.append(area)
"

