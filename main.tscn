[sub_resource type="GDScript" id="GDScript_0xm2m"]
script/source = "extends CharacterBody2D

#STORY FLAGS
var flags := {
	\"neighbor_story\": 0,
	\"neighbor_visit_story\": 0,
	\"neighbor_opinion\": 0,
	\"neighbor_gave_money\": 0,
	\"neighbor_asked_about_son\": 0,
	\"neighbor_there\": 1,
	\"neighbor_asking_for_medicine\": 0,
	
	\"factory_introduced\": 0,
	\"factory_work_started\": 0,
	\"factory_items_return\": 0,
	\"factory_successful_boxes\": 0,
	\"factory_successful_boxes_multiplier\": 1,
	
	\"david_opinion\": 0,
	\"david_story\": 0,
	\"david_cinema_visit_planned\": 0,
	\"david_cinema_tonight\": 0,
	\"david_there_evening\": 1,
	\"david_school_messed_up\": 0,
	\"david_woke_up_from_meds\": 0,
	
	\"parents_at_home\": 1,
	\"father_story\": 0,
	\"father_greeted\": 0,
	\"father_there\": 1,
	\"father_caught_cigarets\": 0,
	\"father_told_about_post_office\": 0,
	
	\"cat_introduction\": 0,
	\"cat_hint_key\": 0,
	\"cat_helped_jessie\": 0,
	\"cat_gave_treat\": 0,
	
	\"took_cigarets_from_campfire\": 0,
	
	\"med_lady_friendly\": 0,
	\"med_lady_story\": 0,
	
	\"day_of_the_week\": 1,
	\"time_of_day\": \"morning\",
	
	\"money_6_taken\": 0,
	\"money_5_taken\": 0,
	
	\"school_completed\": 0,
	\"school_first_day\": 1,
	\"school_days\": 5,
	\"recap_tribute\": 0,
	
	\"candy_meeting\": 0,
	\"boniface_expelled\": 0,
	\"jake_recapped\": 0,
	\"jake_intro\": 0,
	\"jake_cinema_planned\": 0,
	\"jake_know_secret\": 1,
	\"jake_borrow_possible\": 0,
	\"jake_borrowed_money\": 0,
	\"jake_borrowed_for_david\": 0,
	\"jake_how_much_knows\": 0,
	
	\"post_office_work_days\": 5,
	
	
	\"permission_level\": 0,
}




@export var max_speed := 150.0
@export var acceleration := 800.0
@export var friction := 1000.0

@export var morning_texture: Texture
@export var evening_texture: Texture

var loaded_data: Dictionary = {}
var nearby_interactables: Array = []
var nearby_items: Array = []

@onready var anim = $AnimatedSprite2D
@onready var time_filter: ColorRect = $\"../TimeUI/TimeFilter\"
@onready var time_image: TextureRect = $\"../TimeUI/TimeImage\"
@onready var inventory_ui: Control = $\"../InventoryUI/Inventory\"
@onready var pauseMenu: Control = $\"../Popups/PausePopup\"

@onready var teleport_layers := [
	$\"../LayerColission\",
	$\"../LayerInteriorColission\",
	$\"../LayerInteriorFurniture\",
]
@onready var dialog_ui = get_node(\"../DialogUI/TextureRect\")


var can_move := true
var is_teleporting := false
var is_sitting := false

@onready var carry_sprite = $CarrySprite
var carried_item_name := \"\"
var is_carrying: bool = false
var carried_amount := 0

var nearby_box_pile = null

func _ready():
	add_to_group(\"player\")
	
	anim.frame_changed.connect(_on_frame_changed)
	
	pauseMenu.confirmed.connect(_on_exit_dialog_confirmed)
	pauseMenu.cancelled.connect(_on_exit_dialog_cancelled)
	
	if SaveManager.loaded_data.size() > 0:
		loaded_data = SaveManager.loaded_data
		flags = loaded_data.get(\"flags\", flags)
		set_time_of_day_fast(loaded_data[\"flags\"][\"time_of_day\"])
		_apply_data()
	AmbientSoundManager.loading_save = false
	
	Global.player_config_changed.connect(_on_player_config_changed)
	_on_player_config_changed()
	Global.post_office_config_changed.connect(_on_post_office_changed)
	_on_post_office_changed()

func _on_player_config_changed():
	max_speed = Global.player_max_speed
	if Global.recap_tribute == 0:
		flags[\"recap_tribute\"] = randi_range(1, 7)
	else:
		flags[\"recap_tribute\"] = Global.recap_tribute

func _on_post_office_changed():
	flags[\"factory_successful_boxes_multiplier\"] = Global.post_office_salary
	flags[\"post_office_work_days\"] = Global.post_office_work_days
	flags[\"school_days\"] = Global.school_days
	

func _apply_data():
	global_position = loaded_data.get(\"player_position\", global_position)

func _physics_process(delta):
	if not can_move:
		velocity = Vector2.ZERO
		move_and_slide()
		return
	
	var direction = Vector2.ZERO
	#pohyb
	if Input.is_action_pressed(\"ui_right\"):
		direction.x += 1
	if Input.is_action_pressed(\"ui_left\"):
		direction.x -= 1
	if Input.is_action_pressed(\"ui_down\"):
		direction.y += 1
	if Input.is_action_pressed(\"ui_up\"):
		direction.y -= 1

	direction = direction.normalized()
	if direction != Vector2.ZERO:
		var target_velocity = direction * max_speed
		velocity = velocity.move_toward(target_velocity, acceleration * delta)
	else:
		velocity = velocity.move_toward(Vector2.ZERO, friction * delta)
	
	#animacie
	if direction != Vector2.ZERO:
			if direction.y == -1:
				if is_carrying:
					if anim.animation != \"walkUpCarry\":
						anim.play(\"walkUpCarry\")
				elif anim.animation != \"walkUp\":
					anim.play(\"walkUp\")
			if direction.y == 1:
				if is_carrying:
					if anim.animation != \"walkDownCarry\":
						anim.play(\"walkDownCarry\")
				elif anim.animation != \"walkDown\":
					anim.play(\"walkDown\")
			if direction.y == 0:
				if is_carrying:
					if anim.animation != \"walkDownCarry\":
						anim.play(\"walkDownCarry\")
				elif anim.animation != \"walkDown\":
					anim.play(\"walkDown\")
	else:
		if anim.animation != \"idle\":
			if is_carrying:
				anim.play(\"idleCarry\")
			else:
				anim.play(\"idle\")
	move_and_slide()

#sound handle
func _on_frame_changed():

	if velocity == Vector2.ZERO:
		return

	if anim.frame == 1 or anim.frame == 4:
		play_footstep()

func play_footstep():
	var surface = get_current_footstep_type()
	SoundManager.play_footstep(surface)

func get_current_footstep_type() -> String:
	for layer in teleport_layers:

		var cell = layer.local_to_map(layer.to_local(global_position))
		var tile_data = layer.get_cell_tile_data(cell)
		if tile_data == null:
			continue

		var footstep = tile_data.get_custom_data(\"footstep_sound\")

		if footstep != null:
			return str(footstep)

	return \"default\"


func _unhandled_input(event):
	if event.is_action_pressed(\"pause\"):
		if pauseMenu.visible:
			pauseMenu._on_no_pressed()
		else:
			pauseMenuPopup()
		return
	if event.is_action_pressed(\"quick_save\"):
		SaveManager.perform_quick_save()
	
	if event.is_action_pressed(\"inventory\"):
		if dialog_ui.is_open:
			return
		print(\"Current flags:\", flags)
		print(global_position)
		if !inventory_ui.visible:
			inventory_ui.visible = true
			can_move = false
		else:
			inventory_ui.visible = false
			can_move = true

	if dialog_ui.is_open:
		if dialog_ui.player_choosing:
			if event.is_action_pressed(\"ui_up\"):
				dialog_ui.previous_choice()
			if event.is_action_pressed(\"ui_down\"):
				dialog_ui.next_choice()
			if event.is_action_pressed(\"interact\"):
				dialog_ui.choose_choice()
			return
		if event.is_action_pressed(\"interact\"):
			dialog_ui.next_line()
		return

	if event.is_action_pressed(\"interact\"):
		if dialog_ui.is_open:
			return
		if is_carrying:
			drop_carried_item()
			return
		if nearby_box_pile != null:
			if !is_carrying:
				if nearby_box_pile.take_box():
					is_carrying = true
					anim.play(\"idleCarry\")
					return
		if pickup_item():
			return
		if !nearby_interactables.is_empty():
			try_interact()
		else:
			try_teleport_or_dialog()











func try_teleport_or_dialog():
	for layer in teleport_layers:
		if layer == null:
			continue

		var cell: Vector2i = layer.local_to_map(
			layer.to_local(global_position)
		)

		var tile_data = layer.get_cell_tile_data(cell)
		if tile_data == null:
			continue

		if tile_data.has_custom_data(\"dialog_key\"):
			var dialog_key = tile_data.get_custom_data(\"dialog_key\")
			if dialog_key != \"\":
				dialog_ui.open_dialog(dialog_key)
				return

		
		if tile_data.has_custom_data(\"teleport\"):
			if !(tile_data.get_custom_data(\"teleport\") == Vector2i.ZERO):
					await teleport(layer, tile_data)
					return


func teleport(layer, target):
	if target is TileData:
		var required_flag = target.get_custom_data(\"required_flag\")
		if required_flag != null and required_flag != \"\":
			var required_value = target.get_custom_data(\"required_value\")
			if flags.get(required_flag, null) != required_value:
				print(\"cant teleport flag requirement not met\")
				return
	if is_teleporting:
		return

	is_teleporting = true
	can_move = false

	var final_target: Vector2i
	var soundStringTP

	if target is Vector2i:
		final_target = target
	elif target != null and target.has_method(\"get_custom_data\"):
		final_target = target.get_custom_data(\"teleport\")
		soundStringTP = target.get_custom_data(\"teleportSound\")
	else:
		print(\"Error: teleport target is neither Vector2i nor TileData!\")
		can_move = true
		is_teleporting = false
		return
	if layer == null:
		layer = $\"../LayerInterior\"
	
	if soundStringTP != null:
		SoundManager.playSound(\"res://assets/sound/game_sf/\" + soundStringTP + \".wav\")
	
	Transitioner.set_next_animation(true)
	await get_tree().create_timer(0.9).timeout
	
	var local_pos = layer.map_to_local(final_target)
	local_pos += Vector2(layer.tile_set.tile_size) / 2.0
	global_position = layer.to_global(local_pos)
	EntityManager.refresh_all_entities()

	await get_tree().create_timer(0.8).timeout
	Transitioner.set_next_animation(false)

	if !dialog_ui.is_open:
		can_move = true
	is_teleporting = false




func register_interactable(interactable):
	if interactable == null:
		return
	if interactable.has_method(\"set_can_interact\") and !interactable.can_interact:
		return
	if not nearby_interactables.has(interactable):
		nearby_interactables.append(interactable)
		print(\"interactable registered\")
		print(interactable)

func unregister_interactable(interactable):
	if interactable == null:
		return
	nearby_interactables.erase(interactable)

func try_interact():
	var target = get_closest_interactable()
	if target == null:
		return
	
	if target.has_method(\"interact\"):
		target.interact(self)

func get_closest_interactable():
	if nearby_interactables.is_empty():
		return null
	
	var closest = null
	var closest_distance := INF
	
	for interactable in nearby_interactables:
		if interactable == null or not is_instance_valid(interactable):
			continue
		var distance = global_position.distance_to(interactable.global_position)
		if distance < closest_distance:
			closest_distance = distance
			closest = interactable
	return closest




#items handlers
func _on_area_entered(area):
	if area.is_in_group(\"world_items\"):
		nearby_items.append(area)
	if area.is_in_group(\"world_items_static\"):
		nearby_items.append(area)
	if area.is_in_group(\"box_piles\"):
		nearby_box_pile = area
		print(\"vosiel si\")

func _on_area_exited(area):
	if area.is_in_group(\"world_items\"):
		nearby_items.erase(area)
	if area.is_in_group(\"world_items_static\"):
		nearby_items.erase(area)
	if area.is_in_group(\"box_piles\"):
		nearby_box_pile = null
		print(\"dodisiel si\")

func pickup_item() -> bool:
	cleanup_nearby_items()

	if nearby_items.is_empty():
		print(\"No nearby items\")
		return false

	var item = nearby_items[0]

	if not is_instance_valid(item):
		nearby_items.erase(item)
		return false

	if item.pickup_mode == \"carry\":
		if InventoryManager.add_carry_item(item.item_name):
			is_carrying = true
			SoundManager.playSound(\"res://assets/sound/game_sf/PICK UP shortened.wav\")
			anim.play(\"idleCarry\")
	else:
		InventoryManager.add_item(item.item_name, item.amount)
	nearby_items.erase(item)
	item.queue_free()
	return true

#only for carried items in the carry cointainer other items are droppe in inventory_ui
func drop_carried_item():
	if !is_carrying:
		return

	var carry = InventoryManager.inventory[\"carry\"]
	if carry.is_empty():
		return
	var item_name = carry.keys()[0]

	inventory_ui.spawn_world_item(item_name,1,\"carry\")
	InventoryManager.remove_item(item_name,1)
	SoundManager.playSound(\"res://assets/sound/game_sf/PUT DOWN.wav\")
	is_carrying = false

func cleanup_nearby_items():
	var valid_items: Array = []

	for item in nearby_items:
		if not is_instance_valid(item):
			continue

		if global_position.distance_to(item.global_position) > 40:
			continue

		valid_items.append(item)

	nearby_items = valid_items




func set_time_of_day(time: String):
	if Transitioner == null:
		print(\"Error: Transitioner node not found!\")
		return
	
	Transitioner.set_next_animation(true)
	await get_tree().create_timer(0.9).timeout
	AmbientSoundManager.update_active_ambient()
	if time == \"morning\":
		flags.set(\"neighbor_there\", 1)
		flags.set(\"father_greeted\", 0)
		school_prepare() #set school day to not be done if its not weekend
		time_filter.color = Color(0.006, 0.015, 0.076, 0)
		time_image.texture = morning_texture
	elif time == \"afternoon\":
		time_image.texture = evening_texture
		time_filter.color = Color(0.006, 0.015, 0.076, 0.746)
	time_image.visible = true
	await get_tree().create_timer(0.8).timeout
	Transitioner.set_next_animation(false)
	
func set_time_of_day_fast(time: String):
	if time == \"morning\":
		time_filter.color = Color(0.006, 0.015, 0.076, 0)
		time_image.texture = morning_texture
	elif time == \"afternoon\":
		time_image.texture = evening_texture
		time_filter.color = Color(0.006, 0.015, 0.076, 0.746)
	time_image.visible = true

func school_prepare():
	if flags[\"day_of_the_week\"] != 6 and flags[\"day_of_the_week\"] != 7:
		flags[\"school_completed\"] = 0

func change_day():
	
	if flags.get(\"day_of_the_week\") == 7:
		flags.set(\"day_of_the_week\", 1)
	else:
		flags.set(\"day_of_the_week\", flags.get(\"day_of_the_week\") + 0.5)
		
	var day = flags[\"day_of_the_week\"]

	if day >= 1 and day < 6:
		print(\"workday\")
		if day is float and fmod(day, 1.0) == 0.5:
			print(\"afternoon\")
		else:
			print(\"morning\")
	if day >= 6:
		print(\"weekend\")
	print(flags.get(\"day_of_the_week\"))
	
	if (day == 3 || day == 4):
		flags.set(\"parents_at_home\", 0)
	else:
		flags.set(\"parents_at_home\", 1)





func pauseMenuPopup():
	can_move = false
	pauseMenu.open(\"Return to main menu? Progress will be saved.\")

func _on_exit_dialog_confirmed():
	pauseMenu.close()
	SaveManager.perform_quick_save()
	AmbientSoundManager.stop_ambient(1.0)
	Transitioner.change_scene(\"res://Menus/MainMenuV4.tscn\")

func _on_exit_dialog_cancelled():
	pauseMenu.close()
	can_move = true
